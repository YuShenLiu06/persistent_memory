{
	"nodes":[
		{"id":"d7a36c7fecec4b93","type":"group","x":-820,"y":-940,"width":2200,"height":680,"label":"todo"},
		{"id":"bf2342b92ca0689e","type":"group","x":-480,"y":-1790,"width":1040,"height":790,"label":"更新持久加载上下文 - workfollow/command"},
		{"id":"dbcbdda7e10ed999","type":"group","x":700,"y":-1800,"width":660,"height":665,"label":"文档创建 - SKILL/工作流"},
		{"id":"b6ac2cd9418af3e1","type":"group","x":-1300,"y":-1580,"width":700,"height":580,"label":"搜索流程 - skill/mcp"},
		{
			"id":"b07c0eb8d21065b1",
			"type":"text",
			"text":"搜索流程",
			"styleAttributes":{},
			"x":-1280,
			"y":-1560,
			"width":260,
			"height":60
		},
		{
			"id":"ced981e728fcc102",
			"type":"text",
			"text":"1.索引指向的是单个文档，还是一个区域？",
			"styleAttributes":{},
			"x":-1280,
			"y":-1240,
			"width":260,
			"height":60
		},
		{
			"id":"d48c83a6ddcc6cfd",
			"type":"text",
			"text":"2.上下文指的是整个文档，还是索引指向的部分区域",
			"styleAttributes":{},
			"x":-1280,
			"y":-1080,
			"width":260,
			"height":60
		},
		{
			"id":"fa071d0436698e41",
			"type":"text",
			"text":"通过MCP/SKILL调用外部工具进行语义搜索",
			"styleAttributes":{},
			"x":-880,
			"y":-1400,
			"width":260,
			"height":60
		},
		{
			"id":"d5eb82125e932091",
			"type":"text",
			"text":"触发时机：当用户要求生成文档或者对接口进行了更新时，或者用户主动要求进行文档更新时",
			"styleAttributes":{},
			"x":720,
			"y":-1640,
			"width":260,
			"height":120
		},
		{
			"id":"a3088317afe27bd5",
			"type":"text",
			"text":"总结更新内容",
			"styleAttributes":{},
			"x":720,
			"y":-1440,
			"width":260,
			"height":60
		},
		{
			"id":"024066c3465b3596",
			"type":"text",
			"text":"文档创建以及更新(SKILL/工作流)",
			"styleAttributes":{},
			"x":720,
			"y":-1780,
			"width":260,
			"height":60
		},
		{
			"id":"a8c0f3b1189f100f",
			"type":"text",
			"text":"新增的功能/函数",
			"styleAttributes":{},
			"x":1080,
			"y":-1540,
			"width":260,
			"height":60
		},
		{
			"id":"d340fcdbc273606a",
			"type":"text",
			"text":"更改的功能/函数",
			"styleAttributes":{},
			"x":1080,
			"y":-1440,
			"width":260,
			"height":60
		},
		{
			"id":"b64ab34665875ceb",
			"type":"text",
			"text":"不清楚某些或特定函数的意义，或者API接口如何使用",
			"styleAttributes":{},
			"x":-880,
			"y":-1560,
			"width":260,
			"height":60
		},
		{
			"id":"f368fedded6d78a6",
			"type":"text",
			"text":"更新持久加载上下文",
			"styleAttributes":{},
			"x":-460,
			"y":-1780,
			"width":260,
			"height":60
		},
		{
			"id":"b0f01e3e9ffd6ed3",
			"type":"text",
			"text":"结束",
			"styleAttributes":{"textAlign":"center"},
			"x":-100,
			"y":-1090,
			"width":260,
			"height":60
		},
		{
			"id":"85c8e824e9f6f0f8",
			"type":"text",
			"text":"根据\"持久加载文档格式要求\"要求进行更新(上下文需要自主加载)",
			"styleAttributes":{},
			"x":280,
			"y":-1245,
			"width":260,
			"height":90
		},
		{
			"id":"264b977840a8f950",
			"type":"text",
			"text":"用户键入要求",
			"styleAttributes":{},
			"x":280,
			"y":-1780,
			"width":260,
			"height":60
		},
		{
			"id":"24c43b18f3a5cda2",
			"type":"text",
			"text":"对用户要求进行二次核对(可抽象为新SKILL)",
			"styleAttributes":{},
			"x":280,
			"y":-1520,
			"width":260,
			"height":60
		},
		{
			"id":"5ca3c7cccb986cae",
			"type":"text",
			"text":"删除的功能/函数",
			"styleAttributes":{},
			"x":1080,
			"y":-1360,
			"width":260,
			"height":60
		},
		{
			"id":"6bc867abfce4dd40",
			"type":"text",
			"text":"必须准确说明功能的数据类型，使用方法，返回类型以及返回值等，不得遗漏",
			"styleAttributes":{},
			"x":1080,
			"y":-1275,
			"width":260,
			"height":75
		},
		{
			"id":"dc1327da90aadad9",
			"type":"text",
			"text":"查询是否有文档要求规范/如果无，则参考当前已有文档进行更新或者创建",
			"styleAttributes":{},
			"x":720,
			"y":-1245,
			"width":260,
			"height":90
		},
		{
			"id":"c54058f73bcb35fb",
			"type":"text",
			"text":"用户是否有要求",
			"styleAttributes":{"shape":"diamond","textAlign":"center"},
			"x":-100,
			"y":-1780,
			"width":260,
			"height":60
		},
		{
			"id":"778f6a8f56ee6698",
			"type":"text",
			"text":"自动检索以下类别是否进行了更新\n- 整个项目结构\n- 各个结构功能\n- 初级索引(API文档位置，各个文档地址)\n- 必须遵循规则\n- 强制要求(如那些位置不饿能进行更改)",
			"styleAttributes":{},
			"x":-100,
			"y":-1580,
			"width":260,
			"height":280
		},
		{
			"id":"46ad06393353ecaa",
			"type":"text",
			"text":"是否进行了如上更新？",
			"styleAttributes":{"shape":"diamond","textAlign":"center"},
			"x":-100,
			"y":-1230,
			"width":260,
			"height":60
		},
		{
			"id":"c228d0b9622872ce",
			"type":"text",
			"text":"Kilo支持Agents.md加载上下文",
			"styleAttributes":{},
			"x":-460,
			"y":-660,
			"width":260,
			"height":60
		},
		{
			"id":"4db51b3b2d6ffa3e",
			"type":"text",
			"text":"claude code 支持hook钩子类型进行",
			"styleAttributes":{},
			"x":-460,
			"y":-550,
			"width":260,
			"height":60
		},
		{
			"id":"7dd517f006df2400",
			"type":"text",
			"text":"Docs文件夹下对应文档?",
			"styleAttributes":{},
			"x":-460,
			"y":-430,
			"width":260,
			"height":60
		},
		{
			"id":"d0dc5fe9c5ab5204",
			"type":"text",
			"text":"命名规则",
			"styleAttributes":{},
			"x":-460,
			"y":-340,
			"width":260,
			"height":60
		},
		{
			"id":"61f95540c0461ae9",
			"type":"text",
			"text":"- [ ] 通过SKILL调用脚本使得嵌入模型对新增文件进行向量化",
			"styleAttributes":{},
			"x":-60,
			"y":-590,
			"width":260,
			"height":100
		},
		{
			"id":"5d881d7e1e9482f2",
			"type":"text",
			"text":"- [ ] 文档格式以及储存位置方式",
			"styleAttributes":{},
			"x":-60,
			"y":-460,
			"width":260,
			"height":60
		},
		{
			"id":"2278af419782844f",
			"type":"text",
			"text":"- [ ]  通过SKILL让AI自主更新",
			"styleAttributes":{},
			"x":-60,
			"y":-920,
			"width":260,
			"height":60
		},
		{
			"id":"7953acea1a7f03e2",
			"type":"text",
			"text":"- [ ] 持久化记忆文档结构设计",
			"styleAttributes":{},
			"x":-60,
			"y":-805,
			"width":260,
			"height":60
		},
		{
			"id":"a87370f9c4ba5ccb",
			"type":"text",
			"text":"2.向量知识库（尝试考虑使用PageIndex)",
			"styleAttributes":{},
			"x":700,
			"y":-620,
			"width":260,
			"height":60
		},
		{
			"id":"1cfa0b3e057c81b9",
			"type":"text",
			"text":"1.持久加载上下文\n> claude code 以及一些工具自带",
			"styleAttributes":{},
			"x":700,
			"y":-805,
			"width":260,
			"height":115
		},
		{
			"id":"2b9dabadfac133da",
			"type":"text",
			"text":"- [ ] 通过SKILL/mcp进行相关查询命令",
			"styleAttributes":{},
			"x":-60,
			"y":-370,
			"width":260,
			"height":60
		},
		{
			"id":"5103c8e6fea73c33",
			"type":"text",
			"text":"持久记忆化工具&知识库工具",
			"styleAttributes":{},
			"x":1100,
			"y":-520,
			"width":260,
			"height":60
		},
		{
			"id":"5efc90a1e3c83a2f",
			"type":"text",
			"text":"实现方式:MCP+SKILL+工作流共同实现",
			"styleAttributes":{},
			"x":1100,
			"y":-840,
			"width":260,
			"height":60
		},
		{
			"id":"1ae3c80e84ae3b48",
			"type":"text",
			"text":"目的:自动为Agent提供正在编写文件相关文件的文档",
			"styleAttributes":{},
			"x":1100,
			"y":-680,
			"width":260,
			"height":60
		},
		{
			"id":"4dcd0dc9200cf337",
			"type":"text",
			"text":"所有文档，支持语义搜索，支持Agent通过关键词或者功能来查找相关函数",
			"styleAttributes":{},
			"x":320,
			"y":-620,
			"width":260,
			"height":100
		},
		{
			"id":"df1d2230b1f356f2",
			"type":"text",
			"text":"允许:\n- 通过功能查找函数/api\n- 通过函数/api查找说明",
			"styleAttributes":{},
			"x":320,
			"y":-460,
			"width":260,
			"height":120
		},
		{
			"id":"a5e0d6ec9bd420b9",
			"type":"text",
			"text":"索引指向*文档* 这里使用Qdrant进行向量储存",
			"styleAttributes":{},
			"x":-880,
			"y":-1240,
			"width":260,
			"height":60
		},
		{
			"id":"b20fdd279241165d",
			"type":"text",
			"text":"将相关上下文转发给Agent",
			"styleAttributes":{},
			"x":-880,
			"y":-1080,
			"width":260,
			"height":60
		},
		{
			"id":"944fd462216c54fb",
			"type":"text",
			"text":"- [ ] 对强制流程的技术对齐文档名字和储存地点进行更新",
			"styleAttributes":{},
			"x":-800,
			"y":-400,
			"width":260,
			"height":90
		},
		{
			"id":"7c32b3b8f3cc4131",
			"type":"text",
			"text":"trea支持直接将文件加载到上下文",
			"styleAttributes":{},
			"x":-460,
			"y":-760,
			"width":260,
			"height":60
		},
		{
			"id":"4ee3596bf53e5819",
			"type":"text",
			"text":"这部分暂时不需要",
			"styleAttributes":{},
			"x":-800,
			"y":-710,
			"width":260,
			"height":60
		},
		{
			"id":"270e58552bd86771",
			"type":"text",
			"text":"- [ ] 通过rules要求Agent必须加载这份文档(如何保证？)",
			"styleAttributes":{},
			"x":-60,
			"y":-700,
			"width":260,
			"height":80
		},
		{
			"id":"ed55fcc6052fe5c6",
			"type":"text",
			"text":"例如\n- 整个项目结构\n- 各个结构功能\n- 初级索引(API文档位置，各个文档地址)\n- 必须遵循规则\n- 强制要求(如那些位置不饿能进行更改)",
			"styleAttributes":{},
			"x":320,
			"y":-900,
			"width":260,
			"height":250
		},
		{
			"id":"d1fe206b47d9605a",
